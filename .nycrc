{
  "include": ["src/**"],
  "reporter": ["lcovonly", "codecov", "console-details"],
  "experimental": ["monocart"],
  "extension": [".ts"],
  "checkCoverage": 95,
  "all": true,
  "clean": true,
  "exclude": [
    "src/@types", // Typings exports only
    "src/globals.d.ts" // Typings exports only
  ]
}
