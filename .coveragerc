{
  "include": ["src/**"],
  "reporter": ["text", "lcov", "v8"],
  "extension": [".ts"],
  "reportsDirectory": "poku-coverage",
  "checkCoverage": 95,
  "all": true,
  "clean": true,
  "exclude": [
    "src/@types", // Typings exports only
    "src/globals.d.ts" // Typings exports only
  ],
  "hyperlinks": "vscode"
}
