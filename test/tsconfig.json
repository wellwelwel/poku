{
  "extends": "../tsconfig.json",
  "include": [
    "../src",
    "**/**/*.ts",
    "**/**/*.js",
    "**/**/*.cjs",
    "**/**/*.mjs"
  ],
  "exclude": [
    "__fixtures__/e2e/module-types",
    "__fixtures__/e2e/sintax/invalid-file.js"
  ],
  "compilerOptions": {
    "rootDir": "..",
    "outDir": "../ci",
    "declaration": false,
    "allowJs": true,
    "declarationDir": null
  }
}
